@* @page：声明这是一个 Razor Page，必须放在第一行 *@
@page
@* @model：指定这个页面对应的后台 PageModel 类，页面里用 Model.xxx 访问它的属性 *@
@model ContosoPizza.Pages.PizzaListModel
@{
    @* ViewData 是页面和布局（_Layout.cshtml）之间传递数据的字典
       这里设置标题，_Layout.cshtml 里会读取它显示在 <title> 标签里 *@
    ViewData["Title"] = "披萨列表 🍕";
}

<h1>披萨列表 🍕</h1>

@* ===== 新增表单 ===== *@
@* method="post" 表示提交时发送 POST 请求，触发 PageModel 里的 OnPost() *@
<form method="post">
    @* asp-validation-summary：显示模型级别的验证错误汇总
       ModelOnly 表示只显示模型整体的错误，不显示单个字段的错误 *@
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        @* asp-for：Tag Helper，自动根据属性生成 label 的 for 属性和显示文字
           显示文字来自模型上的 [Display(Name = "...")] *@
        <label asp-for="NewPizza.Name" class="control-label"></label>
        @* asp-for 用在 input 上：自动生成 name、id、type、value 等属性
           name 属性决定表单提交后框架把值绑定到哪个属性 *@
        <input asp-for="NewPizza.Name" class="form-control" />
        @* asp-validation-for：显示该字段的验证错误信息（比如"名称不能为空"）*@
        <span asp-validation-for="NewPizza.Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="NewPizza.Size" class="control-label"></label>
        @* asp-for 用在 select 上：会自动把当前值设为选中状态 *@
        <select asp-for="NewPizza.Size" class="form-control" id="PizzaSize">
            <option value="">-- 请选择尺寸 --</option>
            <option value="Small">小</option>
            <option value="Medium">中</option>
            <option value="Large">大</option>
        </select>
        <span asp-validation-for="NewPizza.Size" class="text-danger"></span>
    </div>

    <div class="form-group form-check">
        <label class="form-check-label">
            <input class="form-check-input" asp-for="NewPizza.IsGlutenFree" />
            @* Html.DisplayNameFor：读取模型属性上 [Display(Name)] 的值来显示文字
               这样改模型上的 Display(Name) 这里会自动跟着变，不用到处改 *@
            @Html.DisplayNameFor(model => model.NewPizza.IsGlutenFree)
        </label>
    </div>

    <div class="form-group">
        <label asp-for="NewPizza.Price" class="control-label"></label>
        <input asp-for="NewPizza.Price" class="form-control" />
        <span asp-validation-for="NewPizza.Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <input type="submit" value="添加" class="btn btn-primary" />
    </div>
</form>

@* ===== 披萨列表表格 ===== *@
<table class="table mt-5">
    <thead>
        <tr>
            @* Html.DisplayNameFor：复用模型上的 [Display(Name)] 作为表头
               不需要硬写中文，改模型一处即可全页面生效 *@
            <th scope="col">@Html.DisplayNameFor(model => model.NewPizza.Name)</th>
            <th scope="col">@Html.DisplayNameFor(model => model.NewPizza.Price)</th>
            <th scope="col">@Html.DisplayNameFor(model => model.NewPizza.Size)</th>
            <th scope="col">@Html.DisplayNameFor(model => model.NewPizza.IsGlutenFree)</th>
            <th scope="col">操作</th>
        </tr>
    </thead>
    <tbody>
    @* @foreach：Razor 里的 C# 循环语法，@ 开头表示后面是 C# 代码 *@
    @foreach (var pizza in Model.PizzaList)
    {
        <tr>
            <td>@pizza.Name</td>
            @* {pizza.Price:C} 是 C# 格式化字符串，:C 表示货币格式（如 ¥1.00）*@
            <td>@($"{pizza.Price:C}")</td>
            <td>@pizza.Size</td>
            @* 三元表达式：条件 ? 真值 : 假值 *@
            <td>@(pizza.IsGlutenFree ? "✔️" : string.Empty)</td>
            <td>
                @* 点击编辑按钮时调用 JS 函数展开下方的编辑行 *@
                <button class="btn btn-sm btn-info" type="button"
                    onclick="toggleEdit(@pizza.Id)">编辑</button>

                @* asp-page-handler="Delete"：提交到 OnPostDelete() 方法
                   框架会在 URL 后加 ?handler=Delete 来区分不同的 POST handler *@
                @* asp-route-id：把 pizza.Id 作为路由参数传递，
                   OnPostDelete(int id) 里的 id 参数就是从这里来的 *@
                <form method="post" asp-page-handler="Delete" asp-route-id="@pizza.Id" class="d-inline">
                    <button class="btn btn-sm btn-danger">删除</button>
                </form>
            </td>
        </tr>

        @* 编辑行：默认隐藏，点击编辑按钮后通过 JS 显示 *@
        <tr id="edit-row-@pizza.Id" style="display:none">
            <td colspan="5">
                @* 编辑表单：没有 asp-page-handler，提交到默认的 OnPost()
                   通过隐藏字段传入 Id，OnPost() 里判断 Id > 0 就执行更新 *@
                <form method="post" class="d-flex gap-2 align-items-end flex-wrap">
                    @* 隐藏字段：把当前披萨的 Id 随表单一起提交
                       框架绑定到 NewPizza.Id，OnPost() 里用它判断是新增还是编辑 *@
                    <input type="hidden" name="NewPizza.Id" value="@pizza.Id" />
                    <div>
                        <label class="form-label">@Html.DisplayNameFor(m => m.NewPizza.Name)</label>
                        <input name="NewPizza.Name" value="@pizza.Name" class="form-control form-control-sm" required />
                    </div>
                    <div>
                        <label class="form-label">@Html.DisplayNameFor(m => m.NewPizza.Price)</label>
                        <input name="NewPizza.Price" value="@pizza.Price" type="number" step="0.01" class="form-control form-control-sm" required />
                    </div>
                    <div>
                        <label class="form-label">@Html.DisplayNameFor(m => m.NewPizza.Size)</label>
                        @* 编辑时需要把当前值设为选中，用 @if 判断后加 selected *@
                        <select name="NewPizza.Size" class="form-select form-select-sm">
                            @if (pizza.Size == ContosoPizza.Models.PizzaSize.Small) { <option value="Small" selected>小</option> } else { <option value="Small">小</option> }
                            @if (pizza.Size == ContosoPizza.Models.PizzaSize.Medium) { <option value="Medium" selected>中</option> } else { <option value="Medium">中</option> }
                            @if (pizza.Size == ContosoPizza.Models.PizzaSize.Large) { <option value="Large" selected>大</option> } else { <option value="Large">大</option> }
                        </select>
                    </div>
                    <div class="form-check mt-3">
                        @* checkbox 需要手动判断是否 checked，因为 asp-for 在循环里会有 id 冲突 *@
                        <input name="NewPizza.IsGlutenFree" type="checkbox" class="form-check-input"
                            value="true" @(pizza.IsGlutenFree ? "checked" : "") />
                        <label class="form-check-label">@Html.DisplayNameFor(m => m.NewPizza.IsGlutenFree)</label>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-sm btn-primary">保存</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleEdit(@pizza.Id)">取消</button>
                    </div>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

@* @section：向布局页（_Layout.cshtml）的 Scripts 区域注入内容
   _Layout.cshtml 里有 @await RenderSectionAsync("Scripts") 占位符
   这里的内容会被插入到那个位置，确保脚本在页面底部加载 *@
@section Scripts {
    @* 引入客户端验证脚本（配合 asp-validation-for 实时显示错误）*@
    <partial name="_ValidationScriptsPartial" />
    <script>
        // 切换编辑行的显示/隐藏
        function toggleEdit(id) {
            const row = document.getElementById('edit-row-' + id);
            row.style.display = row.style.display === 'none' ? '' : 'none';
        }
    </script>
}
