@page
@model ContosoPizza.Pages.Pizzas.IndexModel
@{
    ViewData["Title"] = "披萨管理 🍕";
}

<h1>披萨管理 🍕</h1>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success">@TempData["Msg"]</div>
}

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-2 align-items-start mb-4">
        <div class="col-md-3">
            <label asp-for="NewPizza.Name" class="form-label"></label>
            <input asp-for="NewPizza.Name" class="form-control" />
            <span asp-validation-for="NewPizza.Name" class="text-danger"></span>
        </div>
        <div class="col-md-2">
            <label asp-for="NewPizza.Size" class="form-label"></label>
            <select asp-for="NewPizza.Size" class="form-select">
                <option value="Small">小</option>
                <option value="Medium">中</option>
                <option value="Large">大</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="NewPizza.Price" class="form-label"></label>
            <input asp-for="NewPizza.Price" class="form-control" />
            <span asp-validation-for="NewPizza.Price" class="text-danger"></span>
        </div>
        <div class="col-md-2 pt-2">
            <div class="form-check mt-3">
                <input asp-for="NewPizza.IsGlutenFree" class="form-check-input" />
                <label asp-for="NewPizza.IsGlutenFree" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-2">
            <label class="form-label">&nbsp;</label>
            <input type="submit" value="添加" class="btn btn-primary w-100 d-block" />
        </div>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.NewPizza.Name)</th>
            <th>@Html.DisplayNameFor(m => m.NewPizza.Size)</th>
            <th>@Html.DisplayNameFor(m => m.NewPizza.Price)</th>
            <th>@Html.DisplayNameFor(m => m.NewPizza.IsGlutenFree)</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var pizza in Model.PizzaList)
    {
        <tr>
            <td>@pizza.Name</td>
            <td>@pizza.Size</td>
            <td>@($"{pizza.Price:C}")</td>
            <td>@(pizza.IsGlutenFree ? "✔️" : "-")</td>
            <td>
                <button class="btn btn-sm btn-outline-primary" type="button" onclick="toggleEdit(@pizza.Id)">编辑</button>
                <form method="post" asp-page-handler="Delete" asp-route-id="@pizza.Id" class="d-inline">
                    <button class="btn btn-sm btn-outline-danger">删除</button>
                </form>
            </td>
        </tr>
        <tr id="edit-@pizza.Id" style="display:none" class="table-light">
            <td colspan="5">
                <form method="post" class="row g-2 align-items-end p-2">
                    <input type="hidden" name="NewPizza.Id" value="@pizza.Id" />
                    <div class="col-md-3">
                        <input name="NewPizza.Name" value="@pizza.Name" class="form-control form-control-sm" required />
                    </div>
                    <div class="col-md-2">
                        <select name="NewPizza.Size" class="form-select form-select-sm">
                            @if (pizza.Size == ContosoPizza.Models.PizzaSize.Small) { <option value="Small" selected>小</option> } else { <option value="Small">小</option> }
                            @if (pizza.Size == ContosoPizza.Models.PizzaSize.Medium) { <option value="Medium" selected>中</option> } else { <option value="Medium">中</option> }
                            @if (pizza.Size == ContosoPizza.Models.PizzaSize.Large) { <option value="Large" selected>大</option> } else { <option value="Large">大</option> }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input name="NewPizza.Price" value="@pizza.Price" type="number" step="0.01" class="form-control form-control-sm" required />
                    </div>
                    <div class="col-md-2">
                        <div class="form-check mt-1">
                            <input name="NewPizza.IsGlutenFree" type="checkbox" class="form-check-input" value="true" @(pizza.IsGlutenFree ? "checked" : "") />
                            <label class="form-check-label">无麸质</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-sm btn-primary">保存</button>
                        <button type="button" class="btn btn-sm btn-secondary" onclick="toggleEdit(@pizza.Id)">取消</button>
                    </div>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleEdit(id) {
            const row = document.getElementById('edit-' + id);
            row.style.display = row.style.display === 'none' ? '' : 'none';
        }
    </script>
}
